    "model_details": {
      "deepgram": {
        "nova-3": {
          "description": "Latest general ASR; Indian langs per Deepgram docs (nova-3 monolingual list). Malayalam and Punjabi are not listed—use other providers.",
          "streaming": true,
          "recommended": true
        },
        "nova-2": {
          "description": "Legacy; Hindi and English (India) among Indic—other Indic use nova-3 only per Deepgram model/language overview.",
          "streaming": true,
          "recommended": false
        },
        "flux-general-en": {
          "description": "Voice agent optimized with turn detection",
          "streaming": true,
          "recommended": true,
          "english_only": true
        }
      },
      "gcp": {
        "chirp_3": {
          "description": "Chirp 3 transcription (see GCP table; not all locales—Urdu/Sanskrit-style langs often need chirp_2).",
          "streaming": true,
          "recommended": true
        },
        "chirp_2": {
          "description": "Previous Chirp version; broader locale coverage when chirp_3 omits a language.",
          "streaming": true,
          "recommended": false
        },
        "long": {
          "description": "Optimized for long audio",
          "streaming": false,
          "recommended": false
        },
        "short": {
          "description": "Optimized for short audio",
          "streaming": true,
          "recommended": false
        },
        "telephony": {
          "description": "Optimized for phone calls",
          "streaming": true,
          "recommended": false
        }
      },
      "sarvam": {
        "saaras:v3": {
          "description": "Saaras v3 STT — 22 Indian languages + English per Sarvam docs (recommended over Saarika for full coverage).",
          "streaming": true,
          "recommended": true
        },
        "saarika:v2": {
          "description": "Legacy Saarika v2 STT",
          "streaming": true,
          "recommended": false
        },
        "saarika:v2.5": {
          "description": "Saarika v2.5 — 11 Indian languages + English; use saaras:v3 for Assamese and other extended languages.",
          "streaming": true,
          "recommended": true
        }
      },
      "ai4bharat": {
        "indic-conformer-stt": {
          "description": "AI4Bharat Indic Conformer ASR model for Indian languages",
          "streaming": true,
          "recommended": true
        }
      },
      "bhashini": {
        "bhashini/ai4bharat/conformer-multilingual-asr": {
